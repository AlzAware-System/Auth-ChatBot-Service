# Local SQL Server configuration (default for this project)
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DB=Alzaware
MSSQL_DRIVER=ODBC Driver 17 for SQL Server
MSSQL_TRUSTED=true

# Use these only if you disable trusted authentication
# MSSQL_USER=your_sql_username
# MSSQL_PASSWORD=your_sql_password

# Optional full connection-string override
# DATABASE_URL=mssql+pyodbc://USERNAME:PASSWORD@SERVER/DB_NAME?driver=ODBC+Driver+17+for+SQL+Server

# Flask / JWT configuration
SECRET_KEY=your_strong_secret_key_here_change_me
JWT_SECRET=your_jwt_secret_here
JWT_EXP_MINUTES=60
FLASK_ENV=development

# Rate limiting
RATE_LIMIT_PER_HOUR=100 per minute
RATELIMIT_STORAGE_URI=memory://

# Google / Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Gmail SMTP configuration
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# AWS / SNS configuration
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
SNS_PLATFORM_APPLICATION_ARN=your_sns_platform_application_arn

# Optional password reset URL templates
# MOBILE_RESET_PASSWORD_URL_TEMPLATE=alzaware://resetpassword?token={token}
# RESET_PASSWORD_DEEP_LINK_TEMPLATE=alzaware://resetpassword?token={token}
# RESET_PASSWORD_CLICK_URL_TEMPLATE=https://your-domain.example/resetpassword?token={token}

# Redis Configuration
REDIS_HOST=your_redis_host_here
REDIS_PORT=10371
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password_here